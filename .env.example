# ============================================================
# TREISHVAAM FINANCE FRONTEND — ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env for local development:
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# NEVER commit .env to git — it is in .gitignore.
# For Production (Cloudflare Pages), set these in:
#   Cloudflare Dashboard → Workers & Pages → treishvaam-finance-frontend
#   → Settings → Environment Variables
#
# NAMING CONVENTION: Only NEXT_PUBLIC_* prefix is valid.
# REACT_APP_* is a Create React App convention — NOT supported here.
# ============================================================


# ============================================================
# BACKEND API
# ============================================================

# The base URL of the Spring Boot backend API.
# For local dev, this is typically the Cloudflare Tunnel URL or localhost:8080.
# For production, this is the Cloudflare Tunnel URL (injected as Worker Secret on the edge).
# Example: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=


# ============================================================
# ANALYTICS & ADVERTISING (Google)
# ============================================================

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Get from: Google Analytics → Admin → Data Streams → Web Stream → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads Conversion Tracking ID
# Format: AW-XXXXXXXXXX
# Get from: Google Ads → Tools & Settings → Conversions → Tag setup
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google AdSense Publisher ID
# Format: ca-pub-XXXXXXXXXXXXXXXX
# Get from: Google AdSense → Account → Account information
NEXT_PUBLIC_ADSENSE_CLIENT_ID=


# ============================================================
# PRIVACY & COMPLIANCE
# ============================================================

# GA4 IP anonymisation toggle.
# Set to "true" to inject anonymize_ip:true into GA4 — enables instant GDPR/DPDP
# compliance without a code rebuild. Default is "false" (full data fidelity
# for Indian jurisdiction per DPDP Act 2023).
# Values: true | false
NEXT_PUBLIC_ENFORCE_STRICT_PRIVACY=false


# ============================================================
# DYNAMIC ASSETS
# ============================================================

# URL for the Chairman/Founder portrait image.
# Stored in MinIO or a Cloudflare media CDN page — NOT in the git repository.
# Changing this value swaps the image instantly without a git commit or rebuild.
# Example: https://media.treishvaamgroup.com/portraits/chairman.webp
NEXT_PUBLIC_CHAIRMAN_PORTRAIT_URL=
