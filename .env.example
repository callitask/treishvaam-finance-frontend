# -------------------------------------------------------------------------
# CONFIGURATION TEMPLATE
# -------------------------------------------------------------------------
# Copy this file to .env and fill in the values for local development.
# For Production (Cloudflare), set these in the Dashboard Environment Variables.
# -------------------------------------------------------------------------

# The URL of your Backend API 
REACT_APP_API_URL=

# The URL of your Identity Provider 
REACT_APP_AUTH_URL=

# -------------------------------------------------------------------------
# THIRD-PARTY INTEGRATIONS (SEO, Analytics, Ads)
# -------------------------------------------------------------------------
# Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
REACT_APP_GA_MEASUREMENT_ID=

# Google Ads Conversion Tracking ID (e.g., AW-XXXXXXXXXX)
REACT_APP_GOOGLE_ADS_ID=

# Google AdSense Publisher ID (e.g., ca-pub-XXXXXXXXXXXXXXXX)
REACT_APP_ADSENSE_CLIENT_ID=